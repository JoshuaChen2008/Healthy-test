generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../docs/schema-erd.svg"
}

datasource db {
  provider = "postgresql"
}

// Prisma enums are used here instead of app-layer-only validation because this
// task does not add API code yet, so the database schema can enforce the sets.
enum Gender {
  male
  female
  other
}

enum Goal {
  lose_weight
  build_muscle
  improve_fitness
  improve_health
}

enum WorkoutFrequency {
  never
  rarely
  few_times_week
  often
  daily
}

enum AssessmentStatus {
  in_progress
  completed
  abandoned
}

enum SubscriptionStatus {
  free
  active
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String?       @unique
  passwordHash String?       @map("password_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  assessments  Assessment[]
  subscription Subscription?
  sessions     Session[]

  @@map("users")
}

model Assessment {
  id                  String            @id @default(uuid()) @db.Uuid
  gender              Gender?
  goal                Goal?
  age                 Int?
  heightCm            Float?            @map("height_cm")
  weightKg            Float?            @map("weight_kg")
  targetWeightKg      Float?            @map("target_weight_kg")
  workoutFrequency    WorkoutFrequency? @map("workout_frequency")
  answers             Json              @default("{}")
  email               String?
  name                String?
  currentStep         Int               @default(0) @map("current_step")
  status              AssessmentStatus  @default(in_progress)
  bmi                 Float?
  recommendedCalories Int?              @map("recommended_calories")
  targetDate          DateTime?         @map("target_date")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  userId              String            @map("user_id") @db.Uuid
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId], map: "assessments_one_in_progress_per_user", where: raw("status = 'in_progress'"))
  @@index([userId])
  @@map("assessments")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.Char(64)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthRateLimit {
  keyHash         String    @id @map("key_hash") @db.Char(64)
  attemptCount    Int       @default(0) @map("attempt_count")
  windowStartedAt DateTime  @map("window_started_at")
  blockedUntil    DateTime? @map("blocked_until")
  expiresAt       DateTime  @map("expires_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("auth_rate_limits")
}

model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @unique @map("user_id") @db.Uuid
  status    SubscriptionStatus @default(free)
  paidAt    DateTime?          @map("paid_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
